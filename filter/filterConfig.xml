<filterConfig>
	<filterGroups>
		<!-- Crossref XML book output -->
		<filterGroup
			symbolic="book=>crossref-xml"
			displayName="plugins.importexport.crossref.displayName"
			description="plugins.importexport.crossref.description"
			inputType="class::classes.submission.Submission[]"
			outputType="xml::schema(https://www.crossref.org/schemas/crossref4.3.7.xsd)" />
	</filterGroups>
	<filters>
		<!-- Crossref XML book output -->
		<filter
			inGroup="book=>crossref-xml"
			class="APP\plugins\generic\crossref\filter\CrossrefXmlFilter"
			isTemplate="0" />
	</filters>
</filterConfig>