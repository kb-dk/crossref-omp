msgid "plugins.importexport.crossref.error.publisherNotConfigured"
msgstr "¡No se ha configurado un editor! Debes añadir una institución editora en la <a href=\"{$pressSettingsUrl}\" target=\"_blank\">Página de Configuración de la Prensa</a>."

msgid "plugins.importexport.crossref.error.noDOIContentObjects"
msgstr "No se han seleccionado libros para la asignación de DOI en el plugin de identificador público DOI, por lo que no hay posibilidad de depósito o exportación en este plugin."

msgid "plugins.importexport.crossref.settings"
msgstr "Configuración de Crossref"

msgid "plugins.importexport.crossref.settings.depositorIntro"
msgstr "Los siguientes elementos son necesarios para un depósito exitoso en Crossref."

msgid "plugins.importexport.crossref.settings.form.depositorName"
msgstr "Nombre del depositante"

msgid "plugins.importexport.crossref.settings.form.depositorName.description"
msgstr "Nombre de la organización que registra los DOIs. Se incluye con los metadatos depositados y se utiliza para registrar quién envió el depósito."

msgid "plugins.importexport.crossref.settings.form.depositorEmail"
msgstr "Correo electrónico del depositante"

msgid "plugins.importexport.crossref.settings.form.depositorEmail.description"
msgstr "Dirección de correo electrónico de la persona responsable de registrar el contenido con Crossref. Se incluye con los metadatos depositados y se utiliza al enviar el correo de confirmación del depósito."

msgid "plugins.importexport.crossref.settings.form.depositorNameRequired"
msgstr "Por favor, introduce el nombre del depositante."

msgid "plugins.importexport.crossref.settings.form.depositorEmailRequired"
msgstr "Por favor, introduce el correo electrónico del depositante."

msgid "plugins.importexport.crossref.registrationIntro"
msgstr ""
"<p>Si deseas utilizar este plugin para registrar Identificadores de Objetos Digitales (DOIs) directamente con <a href=\"http://www.crossref.org/\">Crossref</a>, necesitarás añadir tus <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/\">credenciales de cuenta de Crossref</a> en los campos de nombre de usuario y contraseña a continuación.</p>"
"<p>Dependiendo de tu membresía en Crossref, hay dos formas de ingresar tu nombre de usuario y contraseña:</p>"
"<ul>"
"<li>Si estás utilizando una cuenta organizacional, añade tu <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/#00376\">nombre de usuario y contraseña compartidos</a></li>"
"<li>Si estás utilizando una <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/#00368\">cuenta personal</a>, ingresa tu dirección de correo electrónico y el rol en el campo de nombre de usuario. El nombre de usuario se verá así: email@example.com/rol</li>"
"<li>Si no conoces o no tienes acceso a tus credenciales de Crossref, puedes contactar con <a href=\"https://support.crossref.org/\">soporte de Crossref</a> para obtener ayuda. Sin credenciales, aún puedes exportar metadatos en el formato XML de Crossref, pero no puedes registrar tus DOIs con Crossref desde OJS.</li>"
"</ul>"

msgid "plugins.importexport.crossref.settings.form.username"
msgstr "Nombre de usuario"

msgid "plugins.importexport.crossref.settings.form.username.description"
msgstr "El nombre de usuario de Crossref que se utilizará para autenticar tus depósitos. Si estás utilizando una cuenta personal, por favor consulta el consejo anterior."

msgid "plugins.importexport.crossref.settings.form.usernameRequired"
msgstr "Por favor, introduce el nombre de usuario que obtuviste de Crossref."

msgid "plugins.importexport.crossref.settings.form.automaticRegistration.description"
msgstr "OMP depositará automáticamente los DOIs asignados en Crossref. Ten en cuenta que esto puede tardar un poco después de la publicación (por ejemplo, dependiendo de la configuración de tu cronjob). Puedes verificar todos los DOIs no registrados."

#, fuzzy
msgid "plugins.importexport.crossref.settings.form.testMode.description"
msgstr "Usa la API de prueba de Crossref (entorno de prueba) para el depósito de DOI. Por favor, no olvides eliminar esta opción en producción."

msgid "plugins.importexport.crossref.settings.form.validation"
msgstr "Validar XML. Usa esta opción para la descarga de XML para el registro manual de DOI."

msgid "plugins.importexport.crossref.settings.form.onlyValidateExport"
msgstr "Solo validar exportación. No descargar el archivo."

msgid "plugins.importexport.crossref.status.failed"
msgstr "Error"

msgid "plugins.importexport.crossref.status.registered"
msgstr "Activo"

msgid "plugins.importexport.crossref.status.markedRegistered"
msgstr "Marcado como activo"

msgid "plugins.importexport.crossref.status.notDeposited"
msgstr "No depositado"

msgid "plugins.importexport.crossref.action.register"
msgstr "Depositar"

msgid "plugins.importexport.crossref.statusLegend"
msgstr ""
"\n"
"\t\t<p>Estado del depósito:</p>\n"
"\t\t<p>\n"
"\t\t- No depositado: no se ha realizado ningún intento de depósito para este DOI.<br />\n"
"\t\t- Activo: el DOI ha sido depositado y está resolviendo correctamente.<br />\n"
"\t\t- Fallido: el depósito del DOI ha fallado.<br />\n"
"\t\t- Marcado como activo: el DOI fue marcado manualmente como activo.\n"
"\t\t</p>\n"
"\t\t<p>Solo se muestra el estado del último intento de depósito.</p>\n"
"\t\t<p>Si un depósito ha fallado, por favor resuelve el problema e intenta registrar el DOI nuevamente.</p>"

msgid "plugins.importexport.crossref.action.export"
msgstr "Exportar"

msgid "plugins.importexport.crossref.action.markRegistered"
msgstr "Marcar como activo"

msgid "plugins.importexport.crossref.senderTask.name"
msgstr "Tarea de registro automático de Crossref"

msgid "plugins.importexport.crossref.cliUsage"
msgstr ""
"Uso:\n"
"{$scriptName} {$pluginName} export [xmlFileName] [press_path] books objectId1 [objectId2] ...\n"
"{$scriptName} {$pluginName} register [press_path] books objectId1 [objectId2] ...\n"
""

