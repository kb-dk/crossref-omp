msgid "plugins.importexport.crossref.registrationIntro"
msgstr ""
"<p>Jos haluat käyttää tätä lisäosaa rekisteröidäksesi digitaalisten objektien tunnisteet (DOI) suoraan <a href=\"http://www.crossref.org/\">Crossrefiin</a>, lisää <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/\">Crossref-tilisi tunnistetiedot</a> alla oleviin käyttäjänimi- ja salasanakenttiin.</p>"
"<p>Crossref-jäsenyytesi mukaan on kaksi tapaa antaa käyttäjänimi ja salasana:</p>"
"<ul>"
"<li>Jos käytät organisaatiotiliä, lisää <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/#00376\">jaettu käyttäjänimi ja salasana</a></li>"
"<li>Jos käytät <a href=\"https://www.crossref.org/documentation/member-setup/account-credentials/#00368\">henkilökohtaista tiliä</a>, anna sähköpostiosoite ja rooli käyttäjänimikentässä. Käyttäjänimi näyttää tältä: email@example.com/rooli</li>"
"<li>Jos et tiedä tai sinulla ei ole pääsyä Crossref-tunnuksiin, voit ottaa yhteyttä <a href=\"https://support.crossref.org/\">Crossrefin tukeen</a>. Ilman tunnuksia voit silti viedä metatiedot Crossref XML -muotoon, mutta et voi rekisteröidä DOI-tunnuksia Crossrefiin OMP:stä.</li>"
"</ul>"

msgid "plugins.importexport.crossref.settings.form.username"
msgstr "Käyttäjänimi"

msgid "plugins.importexport.crossref.settings.form.username.description"
msgstr "Crossref-käyttäjänimi, jota käytetään talletusten todennukseen. Jos käytät henkilökohtaista tiliä, katso yllä oleva ohje."

msgid "plugins.importexport.crossref.settings.form.usernameRequired"
msgstr "Anna Crossrefiltä saamasi käyttäjänimi."

msgid "plugins.importexport.crossref.settings.form.automaticRegistration.description"
msgstr "OJS tallettaa annetut DOI-tunnukset automaattisesti Crossrefiin. Huomaa, että tämä voi kestää hetken julkaisun jälkeen (esim. cronjob-asetuksista riippuen). Voit tarkistaa kaikki rekisteröimättömät DOI-tunnukset."

msgid "plugins.importexport.crossref.settings.form.testMode.description"
msgstr "Käytä Crossrefin testirajapintaa (testiympäristöä) DOI-talletukseen. Muista poistaa tämä valinta tuotantoympäristössä."

msgid "plugins.importexport.crossref.settings.form.validation"
msgstr "Tarkista XML. Käytä tätä vaihtoehtoa ladatessasi XML-tiedoston manuaalista DOI-rekisteröintiä varten."

msgid "plugins.importexport.crossref.settings.form.onlyValidateExport"
msgstr "Vain validointi, älä lataa tiedostoa."

msgid "plugins.importexport.crossref.status.failed"
msgstr "Epäonnistui"

msgid "plugins.importexport.crossref.status.registered"
msgstr "Aktiivinen"

msgid "plugins.importexport.crossref.status.markedRegistered"
msgstr "Merkitty aktiiviseksi"

msgid "plugins.importexport.crossref.status.notDeposited"
msgstr "Ei talletettu"

msgid "plugins.importexport.crossref.action.register"
msgstr "Talleta"

msgid "plugins.importexport.crossref.statusLegend"
msgstr ""
"\n"
"\t\t<p>Talletuksen tila:</p>\n"
"\t\t<p>\n"
"\t\t- Ei talletettu: tätä DOI-tunnusta ei ole yritetty tallettaa.<br />\n"
"\t\t- Aktiivinen: DOI on talletettu ja toimii oikein.<br />\n"
"\t\t- Epäonnistui: DOI-talletus epäonnistui.<br />\n"
"\t\t- Merkitty aktiiviseksi: DOI on merkitty manuaalisesti aktiiviseksi.\n"
"\t\t</p>\n"
"\t\t<p>Näytetään vain viimeisimmän talletusyrityksen tila.</p>\n"
"\t\t<p>Jos talletus epäonnistui, korjaa ongelma ja yritä rekisteröidä DOI uudelleen.</p>"

