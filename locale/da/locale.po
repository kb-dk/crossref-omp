msgstr "Registreringen var ikke vellykket! DOI registreringsserveren returnerede en fejl."

msgid "plugins.importexport.crossref.register.success.warning"
msgstr "Registreringen var vellykket, men følgende advarsel opstod: '{$param}'."

msgid "plugins.importexport.crossref.export.error.bookNotFound"
msgstr "Ingen bog matchede det specificerede ID \"{$bookId}\"."

msgid "plugins.generic.crossref.registrationAgency.name"
msgstr "Crossref"

msgid "plugins.generic.crossref.successMessage"
msgstr ""
"Metadata for dette objects er blevet deponeret hos Crossref."
"For at se yderligere detaljer, se venligst indsendelsen i <a href=\"https://doi.crossref.org/servlet/submissionAdmin?sf=detail&submissionID={$submissionId}\\">Crossref admin panel</a>."

